# AssetForge — настройки окружения.
# Скопируй этот файл в `.env` (в корне проекта) и заполни значения.
# Файл `.env` уже в .gitignore — секреты в репозиторий не попадут.
# Реальные переменные окружения (export) имеют приоритет над .env.

# --- БАЗА ДАННЫХ -------------------------------------------------------------
# По умолчанию (если строку не задать) — локальный SQLite-файл assetforge.db.
# Для облака вставь строку подключения Supabase (Session pooler, порт 5432).
# Где взять: supabase.com → твой проект → Project Settings → Database →
#   Connection string → вкладка "Session pooler" → Copy. Подставь пароль БД.
# ASSETFORGE_DB_URL=postgresql+psycopg2://postgres.<ref>:<ПАРОЛЬ>@aws-0-<регион>.pooler.supabase.com:5432/postgres?sslmode=require

# --- БЕЗОПАСНОСТЬ (обязательно в проде) --------------------------------------
# Секрет для подписи cookie-сессий. Сгенерируй: python -c "import secrets;print(secrets.token_urlsafe(48))"
# ASSETFORGE_SECRET=

# Email будущего администратора (этому аккаунту при регистрации выдаются права админа).
# ASSETFORGE_ADMIN_EMAIL=you@example.com

# Признак прод-окружения (включает жёсткие проверки и Secure-cookie).
# ASSETFORGE_ENV=prod
# Публичный адрес сайта (для ссылок в письмах и редиректов оплаты).
# ASSETFORGE_BASE_URL=https://your-domain.com

# --- ВАЛЮТА / ОПЛАТА ---------------------------------------------------------
# RUB (по умолчанию) или USD.
# ASSETFORGE_CURRENCY=RUB
# Провайдер: manual (демо) | stripe | yookassa. Для реальных платежей задать ключи ниже.
# ASSETFORGE_PAYMENTS=manual
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=

# --- EMAIL (для верификации и сброса пароля) ---------------------------------
# console (печать в лог, dev) | smtp
# ASSETFORGE_EMAIL=console
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# ASSETFORGE_EMAIL_FROM=AssetForge <no-reply@your-domain.com>
